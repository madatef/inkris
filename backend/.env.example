# App metadata
APP_NAME=inkris
PORT=8000
DEBUG=true # Set to false in production
MAX_FILE_SIZE_BYTES=max-allowable-file-size-limit
APP_ENVIRONMENT=your-env.example:development

# Databases
DATABASE_URL=postgresql+asyncpg://db-url
DATABASE_URL_SYNC=postgresql+psycopg2://db-url
AGENT_STATE_DATABASE_URL=postgresql://db-url # You might want to add path params to keep connection alive for long writes to avoid gateway timeouts and SSL errors.
AGENT_STATE_DATABASE_URL_ASYNC=postgresql+asyncpg://db-url

# JWT authentication settings
SECRET_KEY=your-very-secret-key
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_NAME="refresh_token"
ACCESS_TOKEN_COOKIE_NAME="access_token"
COOKIE_SECURE=False # True in production
TOKENS_COOKIE_PATH="/api"
TOKENS_COOKIE_SAMESITE="lax"
ACCESS_TOKEN_EXPIRE_MINUTES=15
ALGORITHM=HS256

# Redis and background tasks
CELERY_BROKER_URL=example:<redis://localhost:6379/0> 
CELERY_RESULT_BACKEND=example:<redis://localhost:6379/1>
EVENTS_BROKER_URL=example:<redis://localhost:6379/2>

# AWS services
AWS_ACCESS_KEY_ID=your-aws-credentials
AWS_SECRET_ACCESS_KEY=your-aws-credentials
AWS_REGION=example:eu-north-1
AWS_S3_BUCKET=your-s3-cloud-bucket-name # for files, should be private
AWS_S3_MEDIA_BUCKET=your-s3-cloud-bucket-name # for images and videos generated by AI, should be public to be viewed in conversations without expiry

# Qdrant congig
QDRANT_URL=your-Qdrant-cluster-url
QDRANT_API_KEY=cluster-api-key
QDRANT_COLLECTION=Qdrant-collection-name.example:inkris-collection

# LLM providers
OPENAI_API_KEY=your-secret-openai-api-key
ORCHESTRATOR_OPENAI_MODEL=openai-model
RAG_OPENAI_MODEL=openai-model
SUMMARIZATION_OPENAI_MODEL=openai-model

# Web search and crawling
JINA_API_KEY=your-secret-key
SERPER_API_KEY=your-secret-key

# Agent tracing
LANGCHAIN_API_KEY=lsv2_sk_xxxx # Replace with your key
LANGCHAIN_TRACING_V2=true # Set to false to stop tracing
LANGCHAIN_PROJECT="inkris-agent-monitoring" # Or any name you want. This name is used for filtering and isolation in LangSmith UI
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com" # Optional, but recommended. Don't change the value